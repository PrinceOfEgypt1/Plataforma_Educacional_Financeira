    "/api/v1/contract/ping": {
      "get": {
        "tags": [
          "contract"
        ],
        "summary": "Prova de vida do contrato-base de sucesso (Doc 06 §4.1)",
        "operationId": "contract_ping_api_v1_contract_ping_get",
        "parameters": [
          {
            "name": "echo",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
