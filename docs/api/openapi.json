          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Meta": {
        "properties": {
          "request_id": {
            "type": "string",
            "title": "Request Id",
            "description": "Identificador único da requisição (UUID4), propagado em X-Request-ID."
          },
          "version": {
            "type": "string",
            "title": "Version",
            "description": "Versão da API que respondeu (casa com o prefixo /api/v1).",
            "default": "v1"
          },
          "generated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Generated At",
            "description": "Timestamp ISO-8601 UTC do momento de geração da resposta."
          }
        },
        "type": "object",
        "required": [
          "request_id",
          "generated_at"
        ],
        "title": "Meta",
        "description": "Metadados canônicos do envelope de sucesso (Doc 06 §4.1)."
      },
      "PingData": {
        "properties": {
          "pong": {
            "type": "boolean",
            "title": "Pong"
          },
